# Release test: build wheel from source, install cleanly (no editable install), run CLI e2e tests.
# This validates that all package-data (YAML descriptors, configs) is correctly bundled in the wheel.
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV AUDIAGENTIC_DOCKER_TESTS=1

# Build the wheel
WORKDIR /build
COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --no-cache-dir --no-compile setuptools wheel build \
    && python -m build --wheel --no-isolation --outdir /dist \
    && ls /dist

# Clean install from wheel in a fresh working dir
WORKDIR /app
RUN pip install --no-cache-dir --no-compile /dist/*.whl "mcp>=1.0" pytest

# Template root: managed files that baseline_sync reads from.
# In production the user has these from an installed/extracted repo template.
COPY .audiagentic/config /template/.audiagentic/config
COPY .audiagentic/prompts /template/.audiagentic/prompts
COPY .audiagentic/skills /template/.audiagentic/skills
COPY .audiagentic/planning/config /template/.audiagentic/planning/config
COPY .claude /template/.claude
COPY .gemini /template/.gemini
COPY .github/workflows /template/.github/workflows
COPY .opencode /template/.opencode
COPY AGENTS.md CLAUDE.md GEMINI.md /template/

ENV AUDIAGENTIC_REPO_ROOT=/template

# Test suite only — no src in this image
COPY tests ./tests

CMD ["pytest", "tests/e2e/cli", "-v"]
