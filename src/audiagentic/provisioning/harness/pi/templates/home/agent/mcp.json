{
  "settings": {
    "toolPrefix": "mcp",
    "idleTimeout": 10,
    "directTools": true
  },
  "mcpServers": {
    "audiagentic-provisioning": {
      "command": "__AUDIAGENTIC_PYTHON__",
      "args": [
        "-m",
        "audiagentic.provisioning.mcp.server",
        "--readonly",
        "--smoke-only"
      ],
      "env": {
        "PYTHONPATH": "__AUDIAGENTIC_SRC__",
        "AUDIAGENTIC_REPO_ROOT": "__AUDIAGENTIC_REPO_ROOT__"
      },
      "lifecycle": "lazy",
      "directTools": [
        "audiagentic_provisioning_audiagentic_smoke_status"
      ]
    },
    "audiagentic-project": {
      "command": "__AUDIAGENTIC_PYTHON__",
      "args": [
        "-m",
        "audiagentic.provisioning.mcp.project_server"
      ],
      "env": {
        "PYTHONPATH": "__AUDIAGENTIC_SRC__",
        "AUDIAGENTIC_REPO_ROOT": "__AUDIAGENTIC_REPO_ROOT__"
      },
      "lifecycle": "lazy"
    },
    "audiagentic-planning": {
      "command": "__AUDIAGENTIC_PYTHON__",
      "args": [
        "-m",
        "audiagentic.provisioning.mcp.planning_server"
      ],
      "env": {
        "PYTHONPATH": "__AUDIAGENTIC_SRC__",
        "AUDIAGENTIC_REPO_ROOT": "__AUDIAGENTIC_REPO_ROOT__"
      },
      "lifecycle": "lazy"
    },
    "audiagentic-providers": {
      "command": "__AUDIAGENTIC_PYTHON__",
      "args": [
        "-m",
        "audiagentic.provisioning.mcp.providers_server"
      ],
      "env": {
        "PYTHONPATH": "__AUDIAGENTIC_SRC__",
        "AUDIAGENTIC_REPO_ROOT": "__AUDIAGENTIC_REPO_ROOT__"
      },
      "lifecycle": "lazy"
    },
    "audiagentic-release-please": {
      "command": "__AUDIAGENTIC_PYTHON__",
      "args": [
        "-m",
        "audiagentic.provisioning.mcp.release_please_server"
      ],
      "env": {
        "PYTHONPATH": "__AUDIAGENTIC_SRC__",
        "AUDIAGENTIC_REPO_ROOT": "__AUDIAGENTIC_REPO_ROOT__"
      },
      "lifecycle": "lazy"
    }
  }
}
