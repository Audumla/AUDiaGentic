{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "contract-version",
    "installation-kind",
    "current-version",
    "previous-version",
    "components",
    "providers",
    "last-lifecycle-action",
    "updated-at"
  ],
  "properties": {
    "contract-version": {"const": "v1"},
    "installation-kind": {
      "type": "string",
      "enum": ["fresh", "cutover", "update"]
    },
    "current-version": {"type": "string"},
    "previous-version": {"type": ["string", "null"]},
    "components": {"type": "object"},
    "providers": {"type": "object"},
    "last-lifecycle-action": {"type": "string"},
    "updated-at": {"type": "string"}
  }
}
