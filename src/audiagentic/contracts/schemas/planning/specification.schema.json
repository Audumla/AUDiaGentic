{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "label",
    "state",
    "summary",
    "request_refs",
    "task_refs"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "workflow": {
      "type": "string"
    },
    "standard_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "meta": {
      "type": "object"
    },
    "deleted": {
      "type": "boolean"
    },
    "deleted_at": {
      "type": "string"
    },
    "deletion_reason": {
      "type": "string"
    },
    "archived_at": {
      "type": ["string", "null"]
    },
    "archived_by": {
      "type": ["string", "null"]
    },
    "archive_reason": {
      "type": ["string", "null"]
    },
    "restored_at": {
      "type": ["string", "null"]
    },
    "restored_by": {
      "type": ["string", "null"]
    },
    "request_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_refs": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "required": [
          "ref"
        ],
        "properties": {
          "ref": {
            "type": "string"
          },
          "seq": {
            "type": "integer"
          },
          "display": {
            "type": [
              "string",
              "number"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
