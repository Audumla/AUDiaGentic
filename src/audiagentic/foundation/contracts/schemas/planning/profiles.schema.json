{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "planning": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "guidance_levels": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/guidance_level" }
        },
        "profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "description": { "type": "string" },
              "label": { "type": "string" },
              "on_create": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "type": "string" },
                    "label_suffix": { "type": "string" },
                    "summary_template": { "type": "string" },
                    "domain": { "type": "string" },
                    "refs": { "type": "object" }
                  },
                  "required": ["kind"]
                }
              },
              "allow_plan_overlay": { "type": "boolean" },
              "defaults": { "type": "object" },
              "suggested_sections": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["description", "label"]
          }
        },
        "object_profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "applies_to": { "type": "string" },
              "required_sections": { "type": "array", "items": { "type": "string" } },
              "suggested_sections": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["applies_to"]
          }
        },
        "default_references": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "document_templates": {
          "$ref": "#/$defs/document_templates"
        },
        "relationship_config": {
          "$ref": "#/$defs/relationship_config"
        },
        "required_sections": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "state_section_requirements": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "required": ["planning"],
  "$defs": {
    "guidance_level": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "label": { "type": "string" },
        "defaults": { "type": "object" },
        "sections_by_kind": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "required": { "type": "array", "items": { "type": "string" } },
              "suggested": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "acceptance_criteria_depth": { "type": "string" },
        "semantics": { "type": "object" }
      },
      "required": ["description", "label"]
    },
    "document_templates": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/template_config" }
    },
    "template_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": { "type": "string" },
        "by_guidance": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "required": ["default"]
    },
    "relationship_config": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/relationship_rules" }
    },
    "relationship_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "can_reference": { "type": "array", "items": { "type": "string" } },
        "required_for_children": { "type": "array", "items": { "type": "string" } },
        "referenced_by": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "requires_children": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "states": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["states"]
          }
        }
      },
      "required": ["can_reference"]
    }
  }
}
