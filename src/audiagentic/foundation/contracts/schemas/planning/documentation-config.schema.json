{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "planning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documentation"],
      "properties": {
        "documentation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "root", "surfaces"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "root": {
              "type": "string"
            },
            "surfaces": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "path",
                  "kind",
                  "mode",
                  "profile",
                  "update_policy"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "path": {
                    "type": "string"
                  },
                  "kind": {
                    "type": "string"
                  },
                  "mode": {
                    "enum": [
                      "manual",
                      "hybrid",
                      "managed"
                    ]
                  },
                  "profile": {
                    "type": "string"
                  },
                  "update_policy": {
                    "type": "string"
                  },
                  "entry": {
                    "type": "boolean"
                  },
                  "seed_on_install": {
                    "type": "boolean"
                  }
                }
              }
            },
            "collections": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "path",
                  "format",
                  "output"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "path": {
                    "type": "string"
                  },
                  "include": {
                    "type": "string"
                  },
                  "format": {
                    "enum": [
                      "path",
                      "frontmatter"
                    ]
                  },
                  "output": {
                    "$ref": "#/$defs/value_map"
                  },
                  "filters": {
                    "$ref": "#/$defs/value_map"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "required": ["planning"],
  "$defs": {
    "value_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "enum": [
            "relative_path",
            "stem",
            "frontmatter"
          ]
        },
        "key": {
          "type": "string"
        },
        "mode": {
          "enum": [
            "equals",
            "contains"
          ]
        }
      }
    },
    "value_map": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/value_spec"
      }
    }
  }
}
