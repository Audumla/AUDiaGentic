{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Supporting doc",
  "type": "object",
  "required": ["id", "label", "state", "role", "supports", "owner", "status", "summary"],
  "properties": {
    "id": {"type": "string"},
    "label": {"type": "string"},
    "state": {"type": "string"},
    "role": {"enum": ["analysis", "standard", "execution_reference", "validation", "migration", "coverage", "decision"]},
    "supports": {"type": "array", "items": {"type": "string"}},
    "owner": {"type": "string"},
    "used_by": {"type": "array", "items": {"type": "string"}},
    "status": {"enum": ["draft", "active", "superseded"]},
    "summary": {"type": "string"}
  }
}
