{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "label",
    "state",
    "summary",
    "source",
    "current_understanding",
    "open_questions"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "guidance": {
      "type": "string",
      "enum": ["light", "standard", "deep"]
    },
    "workflow": {
      "type": "string"
    },
    "spec_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "standard_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "meta": {
      "type": "object"
    },
    "deleted": {
      "type": "boolean"
    },
    "deleted_at": {
      "type": "string"
    },
    "deletion_reason": {
      "type": "string"
    },
    "archived_at": {
      "type": ["string", "null"]
    },
    "archived_by": {
      "type": ["string", "null"]
    },
    "archive_reason": {
      "type": ["string", "null"]
    },
    "restored_at": {
      "type": ["string", "null"]
    },
    "restored_by": {
      "type": ["string", "null"]
    },
    "current_understanding": {
      "type": "string"
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
