  ],
  "properties": {
    "profile_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "documentation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required_updates": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
