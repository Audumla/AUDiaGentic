{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "inheritanceRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["direct", "recursive"]
        },
        "sub_inheritance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inheritanceRule"
          }
        }
      },
      "required": ["field"],
      "allOf": [
        {
          "if": {
            "properties": {
              "sub_inheritance": {
                "type": "array"
              }
            },
            "required": ["sub_inheritance"]
          },
          "then": {
            "required": ["type"]
          }
        }
      ]
    },
    "creationExtraFields": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "use_profile_defaults": { "type": "boolean" },
        "use_guidance_defaults": { "type": "boolean" },
        "use_required_sections": { "type": "boolean" },
        "use_profile_sections": { "type": "boolean" },
        "source_field": { "type": "string" },
        "guidance_field": { "type": "string" },
        "context_field": { "type": "string" },
        "understanding_field": { "type": "string" },
        "open_questions_field": { "type": "string" },
        "meta_field": { "type": "string" }
      }
    },
    "creation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duplicate_check": { "type": "boolean" },
        "require_source": { "type": "boolean" },
        "validate_ref_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "refinement_source_prefix": { "type": "string" },
        "refinement_action": { "type": "string" },
        "seed_reference_fields": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "extra_fields": {
          "$ref": "#/$defs/creationExtraFields"
        }
      },
      "dependentRequired": {
        "refinement_source_prefix": ["refinement_action"]
      }
    },
    "workflowActionCreateSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "label": { "type": "string" },
        "summary": { "type": "string" },
        "domain": { "type": ["string", "null"] },
        "workflow": { "type": ["string", "null"] },
        "refs": { "type": "object" },
        "fields": { "type": "object" },
        "check_duplicates": { "type": "boolean" }
      },
      "required": ["kind"]
    },
    "workflowActionUpdateSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": { "type": "string" },
        "ref_field": { "type": "string" },
        "child_id_from": { "type": "string" }
      },
      "required": ["target", "ref_field", "child_id_from"]
    },
    "workflowAction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaults": {
          "type": "object",
          "additionalProperties": true
        },
        "creates": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/workflowActionCreateSpec"
          }
        },
        "updates": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflowActionUpdateSpec" }
        },
        "result_keys": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "required": ["creates"]
    },
    "queueDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "state": { "type": "string" }
      },
      "required": ["kind", "state"]
    },
    "lifecycleActionMetadata": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "null" },
          { "type": "boolean" },
          { "type": "number" }
        ]
      }
    },
    "lifecycleActionCascade": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "by_kind": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "required": ["by_kind"]
    },
    "lifecycleAction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transition_to": { "type": "string" },
        "from_state": { "type": "string" },
        "metadata": { "$ref": "#/$defs/lifecycleActionMetadata" },
        "event_suffix": { "type": "string" },
        "cascade": { "$ref": "#/$defs/lifecycleActionCascade" },
        "extensions": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "properties": {
    "planning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "convention_version",
        "default_profile",
        "default_guidance",
        "naming",
        "dirs",
        "kinds",
        "base_required_fields",
        "base_optional_fields",
        "reference_field_shapes",
        "standard_ref_field",
        "lifecycle"
      ],
      "properties": {
        "convention_version": {
          "type": "integer"
        },
        "default_profile": {
          "type": "string"
        },
        "default_guidance": {
          "type": "string"
        },
        "kind_aliases": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "naming": {
          "type": "object",
          "additionalProperties": false,
          "required": ["numeric_format", "slug_policy", "default_pattern"],
          "properties": {
            "numeric_format": {
              "type": "string"
            },
            "slug_policy": {
              "type": "string"
            },
            "default_pattern": {
              "type": "string"
            }
          }
        },
        "dirs": {
          "type": "object",
          "required": ["base", "attachments", "indexes", "meta", "extracts", "events", "claims", "cache"],
          "properties": {
            "base": { "type": "string" },
            "attachments": { "type": "string" },
            "indexes": { "type": "string" },
            "meta": { "type": "string" },
            "extracts": { "type": "string" },
            "events": { "type": "string" },
            "claims": { "type": "string" },
            "cache": { "type": "string" }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "base_required_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "base_optional_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reference_field_shapes": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["scalar_ref", "scalar_ref_list", "rel_list"]
          }
        },
        "reference_field_targets": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "standard_ref_field": {
          "type": "string"
        },
        "workflow_actions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/workflowAction"
          }
        },
        "queue_defaults": {
          "$ref": "#/$defs/queueDefaults"
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "state_set_priority",
            "state_sets"
          ],
          "properties": {
            "state_set_priority": {
              "type": "object",
              "additionalProperties": {
                "type": "integer"
              }
            },
            "state_sets": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "initial": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "active": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "complete": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "terminal": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "blocked": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            },
            "actions": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/lifecycleAction"
              }
            }
          }
        },
        "kinds": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["dir", "id_prefix", "counter_file", "has_domain", "required_refs", "required_fields", "optional_fields"],
            "properties": {
              "dir": {
                "type": "string"
              },
              "id_prefix": {
                "type": "string"
              },
              "counter_file": {
                "type": "string"
              },
              "has_domain": {
                "type": "boolean"
              },
              "required_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "required_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "optional_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reference_inheritance": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/inheritanceRule"
                  }
                }
              },
              "creation": {
                "$ref": "#/$defs/creation"
              },
              "filename_pattern": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "planning"
  ]
}
