{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "planning": {
      "type": "object",
      "required": [
        "convention_version",
        "dirs",
        "kinds"
      ],
      "properties": {
        "convention_version": {
          "type": "integer"
        },
        "default_profile": {
          "type": "string"
        },
        "default_guidance": {
          "type": "string",
          "enum": ["light", "standard", "deep"]
        },
        "dirs": {
          "type": "object"
        },
        "task_domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "work_package_domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kinds": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["dir", "id_prefix", "counter_file", "has_domain", "required_refs"],
            "properties": {
              "dir": {
                "type": "string"
              },
              "id_prefix": {
                "type": "string"
              },
              "counter_file": {
                "type": "string"
              },
              "has_domain": {
                "type": "boolean"
              },
              "required_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "standard_refs_inheritance": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": ["direct", "recursive"]
                    },
                    "sub_inheritance": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "field": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string",
                            "enum": ["direct", "recursive"]
                          },
                          "sub_inheritance": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "field": {
                                  "type": "string"
                                }
                              },
                              "required": ["field"]
                            }
                          }
                        },
                        "required": ["field"]
                      }
                    }
                  },
                  "required": ["field", "type"]
                }
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "planning"
  ]
}
