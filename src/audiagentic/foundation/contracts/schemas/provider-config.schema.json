{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "contract-version",
    "providers"
  ],
  "properties": {
    "contract-version": {
      "const": "v1"
    },
    "providers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "enabled",
          "install-mode",
          "access-mode"
        ],
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "install-mode": {
            "type": "string"
          },
          "access-mode": {
            "type": "string",
            "enum": [
              "env",
              "cli",
              "none"
            ]
          },
          "base-url": {
            "type": "string"
          },
          "default-model": {
            "type": "string"
          },
          "timeout-seconds": {
            "type": "integer",
            "minimum": 1
          },
          "model-aliases": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "catalog-refresh": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "cli",
                  "api",
                  "static"
                ]
              },
              "max-age-hours": {
                "type": "integer",
                "minimum": 1
              }
            },
            "required": [
              "source"
            ],
            "additionalProperties": false
          },
          "auth-ref": {
            "type": "string",
            "pattern": "^env:[A-Z0-9_]+$"
          },
          "prompt-surface": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "tag-syntax": {
                "type": "string",
                "enum": [
                  "prefix-token-v1"
                ]
              },
              "first-line-policy": {
                "type": "string",
                "enum": [
                  "first-non-empty-line"
                ]
              },
              "cli-mode": {
                "type": "string",
                "enum": [
                  "native-pass-through",
                  "wrapper-normalize",
                  "extension-normalize",
                  "bridge-wrapper",
                  "unsupported"
                ]
              },
              "vscode-mode": {
                "type": "string",
                "enum": [
                  "native-pass-through",
                  "wrapper-normalize",
                  "extension-normalize",
                  "bridge-wrapper",
                  "unsupported"
                ]
              },
              "settings-profile": {
                "type": "string"
              }
            },
            "required": [
              "enabled",
              "tag-syntax",
              "first-line-policy",
              "settings-profile"
            ],
            "additionalProperties": false,
            "allOf": [
              {
                "if": {
                  "properties": {
                    "enabled": {
                      "const": true
                    }
                  }
                },
                "then": {
                  "anyOf": [
                    {
                      "required": [
                        "cli-mode"
                      ]
                    },
                    {
                      "required": [
                        "vscode-mode"
                      ]
                    }
                  ]
                }
              }
            ]
          },
          "execution-policy": {
            "type": "object",
            "properties": {
              "output-format": {
                "type": "string",
                "enum": [
                  "text",
                  "json",
                  "stream-json"
                ]
              },
              "permission-mode": {
                "type": "string",
                "enum": [
                  "auto",
                  "acceptEdits",
                  "bypassPermissions",
                  "default",
                  "dontAsk",
                  "plan"
                ]
              },
              "safety-mode": {
                "type": "string",
                "enum": [
                  "standard",
                  "relaxed",
                  "strict"
                ]
              },
              "auto-approve": {
                "type": "boolean"
              },
              "full-auto": {
                "type": "boolean"
              },
              "ephemeral": {
                "type": "boolean"
              },
              "target-type": {
                "type": "string"
              },
              "timeout-seconds": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "access-mode": {
                  "const": "env"
                }
              }
            },
            "then": {
              "required": [
                "auth-ref"
              ]
            }
          }
        ]
      }
    }
  }
}
