{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "contract-version",
    "job-id",
    "packet-id",
    "project-id",
    "provider-id",
    "workflow-profile",
    "state",
    "created-at",
    "updated-at",
    "artifacts",
    "approvals"
  ],
  "properties": {
    "contract-version": {
      "const": "v1"
    },
    "job-id": {
      "type": "string"
    },
    "packet-id": {
      "type": "string"
    },
    "project-id": {
      "type": "string"
    },
    "provider-id": {
      "type": "string"
    },
    "workflow-profile": {
      "type": "string",
      "enum": [
        "lite",
        "standard",
        "strict"
      ]
    },
    "state": {
      "type": "string",
      "enum": [
        "created",
        "ready",
        "running",
        "awaiting-approval",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "created-at": {
      "type": "string"
    },
    "updated-at": {
      "type": "string"
    },
    "artifacts": {
      "type": "array"
    },
    "approvals": {
      "type": "array"
    },
    "model-id": {
      "type": [
        "string",
        "null"
      ]
    },
    "model-alias": {
      "type": [
        "string",
        "null"
      ]
    },
    "default-model": {
      "type": [
        "string",
        "null"
      ]
    },
    "launch-source": {
      "type": "object",
      "properties": {
        "prompt-id": {
          "type": "string"
        },
        "surface": {
          "type": "string",
          "enum": [
            "cli",
            "vscode"
          ]
        },
        "session-id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "prompt-id",
        "surface",
        "session-id"
      ],
      "additionalProperties": false
    },
    "launch-tag": {
      "type": "string",
      "enum": [
        "ag-plan",
        "ag-implement",
        "ag-review",
        "ag-audit",
        "ag-check-in-prep"
      ]
    },
    "launch-target": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "packet",
            "job",
            "artifact",
            "adhoc"
          ]
        },
        "packet-id": {
          "type": "string"
        },
        "job-id": {
          "type": "string"
        },
        "artifact-id": {
          "type": "string"
        },
        "artifact-path": {
          "type": "string"
        },
        "adhoc-id": {
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "additionalProperties": false
    },
    "review-policy": {
      "type": "object",
      "properties": {
        "required-reviews": {
          "type": "integer",
          "minimum": 1
        },
        "aggregation-rule": {
          "type": "string",
          "enum": [
            "all-pass",
            "majority-pass"
          ]
        },
        "require-distinct-reviewers": {
          "type": "boolean"
        }
      },
      "required": [
        "required-reviews",
        "aggregation-rule",
        "require-distinct-reviewers"
      ],
      "additionalProperties": false
    },
    "review-bundle-id": {
      "type": [
        "string",
        "null"
      ]
    },
    "planning-task-id": {
      "type": "string",
      "description": "Planning task that originated this job (e.g. task-0003). Set at dispatch time by the planning dispatch hook."
    },
    "planning-wp-id": {
      "type": "string",
      "description": "Planning work-package associated with this job (e.g. wp-0001). Optional; set when a WP-level dispatch is used."
    }
  }
}
