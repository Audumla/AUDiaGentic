{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "contract-version"
  ],
  "properties": {
    "contract-version": {
      "const": "v1"
    },
    "default-profile": {
      "type": "string"
    },
    "generic-tag": {
      "type": "string"
    },
    "tag-aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "provider-aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "directive-aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "extends": {
            "type": "string"
          },
          "tag-aliases": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "provider-aliases": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "directive-aliases": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "prompt-controls": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
