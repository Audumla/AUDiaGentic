{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "contract-version",
    "project-id",
    "project-name",
    "workflow-profile",
    "tracked-docs-root",
    "runtime-root",
    "release-strategy"
  ],
  "properties": {
    "contract-version": {
      "const": "v1"
    },
    "project-id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "project-name": {
      "type": "string",
      "minLength": 1
    },
    "workflow-profile": {
      "type": "string",
      "enum": [
        "lite",
        "standard",
        "strict"
      ]
    },
    "tracked-docs-root": {
      "const": "docs"
    },
    "runtime-root": {
      "const": ".audiagentic/runtime"
    },
    "release-strategy": {
      "type": "string"
    },
    "workflow-overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean"
          }
        },
        "required": [
          "enabled"
        ],
        "additionalProperties": false
      }
    },
    "prompt-launch": {
      "type": "object",
      "properties": {
        "syntax": {
          "type": "string",
          "const": "prefix-token-v1"
        },
        "allow-adhoc-target": {
          "type": "boolean"
        },
        "default-review-policy": {
          "type": "object",
          "properties": {
            "required-reviews": {
              "type": "integer",
              "minimum": 1
            },
            "aggregation-rule": {
              "type": "string",
              "enum": [
                "all-pass",
                "majority-pass"
              ]
            },
            "require-distinct-reviewers": {
              "type": "boolean"
            }
          },
          "required": [
            "required-reviews",
            "aggregation-rule",
            "require-distinct-reviewers"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "syntax"
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}