FROM python:3.12-slim

WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV AUDIAGENTIC_DOCKER_TESTS=1

COPY pyproject.toml README.md ./
COPY src ./src
COPY tools ./tools
COPY tests ./tests
COPY docs/examples ./docs/examples
COPY .audiagentic/config ./.audiagentic/config
COPY .audiagentic/prompts ./.audiagentic/prompts
COPY .audiagentic/skills ./.audiagentic/skills
COPY .audiagentic/planning/config ./.audiagentic/planning/config
COPY .claude ./.claude
COPY .gemini ./.gemini
COPY .github/workflows/release-please.audiagentic.yml ./.github/workflows/release-please.audiagentic.yml
COPY .opencode ./.opencode
COPY AGENTS.md CLAUDE.md GEMINI.md ./

RUN pip install --no-cache-dir -e ".[test]"

CMD ["pytest", "tests/unit/lifecycle", "tests/integration/lifecycle", "tests/e2e/lifecycle", "tests/unit/providers", "tests/integration/providers", "tests/integration/release", "tests/e2e/release", "-q"]
